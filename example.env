# townsquare configuration — copy to .env and fill in.

HOST=0.0.0.0
PORT=8000
RUNTIME_ENV=dev

# Generate with: townsquare gen-secrets
SECRET_KEY=
FERNET_KEY=

DB_URL=postgresql+psycopg://townsquare:townsquare@localhost:5432/townsquare

# Google Workspace SSO
# 1. Create OAuth client at console.cloud.google.com → Credentials
# 2. Authorized redirect URI: <your-host>/auth/google/callback
# 3. For Zingly v0.1: OAuth consent screen User Type = INTERNAL
#    so only @zingly.com users can authenticate (no Google verification needed).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
WORKSPACE_DOMAIN=zingly.com
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

PER_USER_QUERY_BUDGET_USD_DAILY=5.0
PER_QUERY_TOKEN_CAP=50000

LOG_LEVEL=INFO
ENABLE_AUDIT_LOG=true
